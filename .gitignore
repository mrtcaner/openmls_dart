# https://dart.dev/guides/libraries/private-files
# Created by `dart pub`
.dart_tool/

# Flutter generated plugin files
.flutter-plugins
.flutter-plugins-dependencies

# FVM (Flutter Version Management)
# Configuration is in .fvmrc, everything in .fvm/ is generated by `fvm install`
.fvm/

# Avoid committing pubspec.lock for library packages; see
# https://dart.dev/guides/libraries/private-files#pubspeclock.
pubspec.lock

# IDE files
.idea/
*.iml
*.ipr
*.iws
# .vscode/ is committed for FVM settings

# Claude Code
.claude/settings.local.json

# Development files
TODO.md
.skip_openmls_hook
# Local cross-repository handoff documents; public traceability belongs in
# GitHub issues and pull requests.
KURTUBA_*_CHANGE_REQUEST.md

# Flutter metadata
.metadata

# The package ships no platform-plugin scaffolding (native delivery is via
# hook/build.dart); keep any stale IDE/Xcode artifacts that reappear in the
# old platform dirs out of git. Anchored so example/ios etc. are unaffected.
/android/
/ios/
/macos/
/linux/
/windows/

# Miscellaneous
.DS_Store
*.log

# Build output
build/

# Coverage
coverage/

# Generated documentation
doc/
docs/

# Rust
rust/target/

# Example Podfile.lock (not committed for library packages)
example/ios/Podfile.lock
example/macos/Podfile.lock

# Downloaded WASM files (auto-downloaded by hook/build.dart)
example/web/pkg/

# FRB generated (optional: you may want to track these)
# lib/src/rust/frb_generated*.dart
# rust/src/frb_generated.rs
