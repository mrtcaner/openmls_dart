# The package ships no platform-plugin scaffolding; native delivery is via
# hook/build.dart, so nothing from the old platform dirs belongs in the
# published package (they may reappear locally as stale IDE/Xcode artifacts).
# Anchored with a leading slash so example/ios etc. are unaffected.
/android/
/ios/
/macos/
/linux/
/windows/
